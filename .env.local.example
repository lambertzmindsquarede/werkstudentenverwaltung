# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Supabase Dashboard > Project Settings > API

# Azure AD credentials are configured in Supabase dashboard:
# Authentication > Providers > Azure
# (Client ID, Client Secret, Tenant ID entered there — not needed as env vars here)

# PROJ-7: Lokaler Dev-Login (nur .env.local, niemals in Production setzen!)
NEXT_PUBLIC_DEV_LOGIN_ENABLED=true
DEV_LOGIN_ENABLED=true
